{
  "name": "purify",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "purify": "dist/cli.js",
    "purify-mcp": "dist/mcp.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepare": "node build.mjs",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "aisp-validator": "^0.3.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1"
  }
}
